{
  "name": "openx",
  "version": "2.5.0",
  "private": true,
  "productName": "OpenX",
  "description": "Deterministic, local-first Windows desktop assistant",
  "main": "apps/desktop/electron/main.js",
  "type": "commonjs",
  "author": "RAKESH",
  "license": "MIT",
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=18.18.0 <23",
    "npm": ">=9"
  },
  "keywords": [
    "assistant",
    "automation",
    "desktop",
    "electron",
    "local-first",
    "offline",
    "openx",
    "windows"
  ],
  "scripts": {
    "start": "node scripts/start-electron.js",
    "dev": "node scripts/start-electron.js --dev",
    "lint": "eslint .",
    "test": "mocha \"tests/**/*.test.js\"",
    "test:core": "mocha \"tests/core/**/*.test.js\"",
    "test:automation": "mocha \"tests/automation/**/*.test.js\"",
    "test:context": "mocha \"tests/context-awareness/**/*.test.js\" \"tests/core/human-context.test.js\"",
    "test:learning": "mocha \"tests/core/active-learning-v2.test.js\" \"tests/core/learning.test.js\" \"tests/core/learning-repair.test.js\"",
    "test:ui": "mocha \"tests/ui/**/*.test.js\"",
    "validate": "npm run lint && npm test",
    "build": "electron-builder --dir --win --x64",
    "package": "electron-builder --win nsis --x64"
  },
  "dependencies": {
    "active-win": "8.2.1",
    "archiver": "^8.0.0",
    "fuse.js": "7.4.1",
    "qrcode": "^1.5.4",
    "sherpa-onnx-node": "^1.13.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "8.57.0",
    "chai": "4.5.0",
    "electron": "28.3.3",
    "electron-builder": "24.13.3",
    "eslint": "8.57.1",
    "globals": "17.6.0",
    "mocha": "10.8.2"
  },
  "build": {
    "appId": "com.openx.assistant",
    "productName": "OpenX",
    "copyright": "Copyright (c) 2024-2026 RAKESH",
    "asar": true,
    "compression": "maximum",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "apps/**/*",
      "core/**/*",
      "plugins/**/*",
      "config.js",
      "package.json",
      "!**/*.test.js",
      "!**/*.spec.js",
      "!**/*.md",
      "!**/.DS_Store",
      "!**/Thumbs.db"
    ],
    "win": {
      "icon": "build/icon.ico",
      "artifactName": "OpenX-Setup-${version}-${arch}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OpenX",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false,
      "include": "build/installer.nsh"
    }
  }
}
