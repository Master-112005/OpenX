{
  "name": "openx",
  "productName": "OpenX",
  "version": "1.0.0",
  "description": "Intelligent Windows Desktop Assistant Platform - Offline chat-driven deterministic automation engine",
  "main": "apps/desktop/electron/main.js",
  "author": "OpenX Team",
  "license": "MIT",
  "scripts": {
    "start": "node scripts/start-electron.js",
    "dev": "node scripts/start-electron.js --dev",
    "test": "mocha tests/**/*.test.js --recursive",
    "test:core": "mocha tests/core/**/*.test.js --recursive",
    "test:automation": "mocha tests/automation/**/*.test.js --recursive",
    "lint": "eslint .",
    "package": "electron-builder --win",
    "build": "electron-builder --win --x64"
  },
  "keywords": [
    "assistant",
    "windows",
    "automation",
    "chat-control",
    "desktop",
    "offline",
    "openx"
  ],
  "dependencies": {
    "active-win": "^8.2.1",
    "double-metaphone": "^2.0.1",
    "electron-store": "^8.1.0",
    "fuse.js": "^7.4.1",
    "uuid": "^9.0.0"
  },
  "optionalDependencies": {
    "node-windows": "^1.0.0-beta.8"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.0",
    "chai": "^4.3.10",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.57.1",
    "globals": "^17.6.0",
    "mocha": "^10.2.0"
  },
  "build": {
  "appId": "com.openx.assistant",
  "productName": "OpenX",
  "copyright": "Copyright (c) 2024 OpenX Team",

  "directories": {
    "output": "dist",
    "buildResources": "build"
  },

    "files": [
      "apps/**/*",
      "config/**/*",
      "core/**/*",
      "plugins/**/*",
      "package.json",

      "!tests/**/*",
      "!docs/**/*",
      "!graphify-out/**/*",
      "!.git/**/*",
      "!.github/**/*",
      "!.cursor/**/*",
      "!.codex/**/*",
      "!.agents/**/*",
      "!.code-review-graph/**/*",
      "!coverage/**/*",
      "!**/*.test.js",
      "!**/*.spec.js",
      "!**/*.md"
    ],

    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "OpenX Setup ${version}.exe"
    },

    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OpenX",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false,
      "include": "build/installer.nsh"
    },

    "asar": true,
    "compression": "maximum"
  }
}
