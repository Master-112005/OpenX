{
  "name": "jarvis-assistant",
  "version": "1.0.0",
  "description": "Intelligent Windows Desktop Assistant Platform - Offline, voice-controlled, deterministic automation engine",
  "main": "apps/desktop/electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "test": "mocha tests/**/*.test.js --recursive",
    "test:core": "mocha tests/core/**/*.test.js --recursive",
    "test:automation": "mocha tests/automation/**/*.test.js --recursive",
    "test:voice": "mocha tests/voice/**/*.test.js --recursive",
    "lint": "eslint .",
    "package": "electron-builder --win"
  },
  "keywords": [
    "assistant",
    "windows",
    "automation",
    "voice-control",
    "desktop",
    "offline"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "active-win": "^8.2.1",
    "double-metaphone": "^2.0.1",
    "electron-store": "^8.1.0",
    "fuse.js": "^7.4.1",
    "uuid": "^9.0.0"
  },
  "optionalDependencies": {
    "node-windows": "^1.0.0-beta.8"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.0",
    "chai": "^4.3.10",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.57.1",
    "globals": "^17.6.0",
    "mocha": "^10.2.0"
  }
}
